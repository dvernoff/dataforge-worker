# ═══════════════════════════════════════════════════════════════
# DataForge — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all values.
# Generate secrets with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

# ── Database Passwords (REQUIRED) ──
POSTGRES_CONTROL_PASSWORD=
POSTGRES_WORKER_PASSWORD=

# ── Redis (optional, leave empty for no auth) ──
REDIS_PASSWORD=

# ── Auth Secrets (REQUIRED — generate with: openssl rand -hex 32) ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
SECRETS_ENCRYPTION_KEY=
ENCRYPTION_KEY=

# ── Worker Node Shared Secret (REQUIRED — generate with: openssl rand -hex 32) ──
WORKER_NODE_API_KEY=

# ── Internal Secret for CP↔Worker /internal/ routes (optional but recommended) ──
INTERNAL_SECRET=

# ── Initial Superadmin (REQUIRED) ──
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=
ADMIN_NAME=Superadmin

# ── CORS Origins (REQUIRED — your domain) ──
CORS_ORIGIN=https://yourdomain.com
WORKER_CORS_ORIGIN=https://yourdomain.com

# ── Ports (optional) ──
CP_PORT=80
WORKER_PORT=8080

# ── Worker Node ID (optional) ──
WORKER_NODE_ID=worker-1

# ── AI (optional) ──
ANTHROPIC_API_KEY=
