{
  "id": "uptime-ping",
  "name": "Uptime Ping",
  "description": "Periodic HTTP health checks for uptime monitoring.",
  "version": "1.0.0",
  "runtime": "worker",
  "icon": "activity",
  "settings": [
    {
      "key": "ping_url",
      "label": "Ping URL",
      "type": "string",
      "required": true,
      "placeholder": "https://example.com/health"
    },
    {
      "key": "interval_seconds",
      "label": "Interval (seconds)",
      "type": "number",
      "required": true,
      "default": 60,
      "placeholder": "60"
    }
  ]
}
