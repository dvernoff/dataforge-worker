{
  "id": "s3-storage",
  "name": "S3 Storage",
  "description": "Upload, download, and manage files in S3-compatible storage (AWS S3, MinIO, etc.).",
  "version": "1.0.0",
  "runtime": "worker",
  "icon": "cloud",
  "settings": [
    {
      "key": "bucket",
      "label": "Bucket Name",
      "type": "string",
      "required": true,
      "placeholder": "my-bucket"
    },
    {
      "key": "region",
      "label": "Region",
      "type": "string",
      "required": true,
      "default": "us-east-1",
      "placeholder": "us-east-1"
    },
    {
      "key": "access_key",
      "label": "Access Key ID",
      "type": "password",
      "required": true
    },
    {
      "key": "secret_key",
      "label": "Secret Access Key",
      "type": "password",
      "required": true
    },
    {
      "key": "endpoint",
      "label": "Custom Endpoint (optional)",
      "type": "string",
      "required": false,
      "placeholder": "https://s3.example.com"
    }
  ]
}
