# ─── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=4001
HOST=0.0.0.0

# ─── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dataforge
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Node Identity & Control Plane ────────────────────────────
NODE_ID=worker-1
NODE_API_KEY=your-secret-api-key-min-16-chars
CONTROL_PLANE_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Rate Limiting (global, per IP) ──────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60000

# ─── Webhooks ─────────────────────────────────────────────────
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3

# ─── Encryption (optional, for secrets storage) ──────────────
# ENCRYPTION_KEY=your-32-byte-hex-key
