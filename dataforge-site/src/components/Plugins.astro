---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const plugins = [
  { icon: '🎮', ...i.plugins.sboxAuth },
  { icon: '📨', ...i.plugins.telegram },
  { icon: '✉️', ...i.plugins.email },
  { icon: '💬', ...i.plugins.discord },
  { icon: '☁️', ...i.plugins.s3 },
  { icon: '💾', ...i.plugins.localStorage },
  { icon: '🔑', ...i.plugins.oauth },
  { icon: '📡', ...i.plugins.uptime },
  { icon: '⏱️', ...i.plugins.cron },
];
---

<section class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-3">{i.plugins.sectionTitle}</h2>
      <p class="text-text-secondary text-sm sm:text-base max-w-lg mx-auto">{i.plugins.sectionSubtitle}</p>
    </div>

    <!-- Horizontal scroll on mobile, grid on desktop -->
    <div class="flex gap-3 overflow-x-auto pb-4 snap-x snap-mandatory lg:grid lg:grid-cols-3 lg:overflow-visible lg:pb-0 stagger">
      {plugins.map((p) => (
        <div class="reveal card-hover glow shrink-0 snap-start w-56 lg:w-auto rounded-xl border border-border-default bg-bg-card p-4">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xl">{p.icon}</span>
            <h3 class="text-sm font-bold text-text-primary whitespace-nowrap">{p.title}</h3>
          </div>
          <p class="text-xs text-text-secondary">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
