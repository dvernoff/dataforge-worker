---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section class="py-20 sm:py-28">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-3">{i.architecture.sectionTitle}</h2>
      <p class="text-text-secondary text-sm sm:text-base max-w-lg mx-auto">{i.architecture.sectionSubtitle}</p>
    </div>

    <!-- Architecture diagram -->
    <div class="reveal">
      <div class="relative overflow-x-auto">
        <div class="min-w-[600px] flex items-center justify-center gap-4 sm:gap-6 py-8">

          <!-- Client -->
          <div class="flex flex-col items-center gap-2">
            <div class="w-20 h-20 rounded-xl border border-border-default bg-bg-card flex items-center justify-center">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text-secondary">
                <rect x="2" y="3" width="20" height="14" rx="2" />
                <path d="M8 21h8M12 17v4" />
              </svg>
            </div>
            <span class="text-xs text-text-muted font-mono">{i.architecture.client}</span>
          </div>

          <!-- Arrow -->
          <div class="flex items-center text-text-muted">
            <svg width="40" height="12" viewBox="0 0 40 12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M0 6h35M30 1l5 5-5 5" />
            </svg>
          </div>

          <!-- BunnyCDN -->
          <div class="flex flex-col items-center gap-2">
            <div class="w-24 h-20 rounded-xl border border-accent-amber/20 bg-accent-amber/5 flex items-center justify-center">
              <span class="text-accent-amber font-mono text-xs font-bold">{i.architecture.cdn}</span>
            </div>
            <span class="text-xs text-text-muted font-mono">CDN</span>
          </div>

          <!-- Arrow + fork -->
          <div class="flex flex-col items-center gap-6">
            <div class="flex items-center text-text-muted">
              <svg width="40" height="12" viewBox="0 0 40 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M0 6h35M30 1l5 5-5 5" />
              </svg>
            </div>
          </div>

          <!-- Worker Node (main box) -->
          <div class="flex flex-col items-center gap-2">
            <div class="rounded-xl border border-accent-blue/20 bg-accent-blue/5 p-4 min-w-[180px]">
              <div class="text-center mb-3">
                <span class="text-accent-blue font-mono text-xs font-bold">{i.architecture.worker}</span>
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div class="rounded-lg bg-bg-card border border-border-default px-2 py-1.5 text-center">
                  <span class="text-[10px] font-mono text-text-muted">{i.architecture.api}</span>
                </div>
                <div class="rounded-lg bg-bg-card border border-border-default px-2 py-1.5 text-center">
                  <span class="text-[10px] font-mono text-text-muted">{i.architecture.database}</span>
                </div>
                <div class="rounded-lg bg-bg-card border border-border-default px-2 py-1.5 text-center">
                  <span class="text-[10px] font-mono text-text-muted">{i.architecture.cache}</span>
                </div>
                <div class="rounded-lg bg-bg-card border border-border-default px-2 py-1.5 text-center">
                  <span class="text-[10px] font-mono text-text-muted">{i.architecture.plugins}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Control Plane (below, separate) -->
        <div class="flex justify-center mt-2">
          <div class="flex items-center gap-4">
            <div class="w-px h-8 bg-border-default"></div>
            <div class="rounded-xl border border-border-default bg-bg-card px-6 py-3 text-center">
              <span class="text-xs font-mono text-text-muted">{i.architecture.controlPlane}</span>
              <span class="text-[10px] text-text-muted block mt-0.5">({i.architecture.uiOnly})</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
