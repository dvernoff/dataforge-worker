---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Architecture from '../components/Architecture.astro';
import Plugins from '../components/Plugins.astro';
import OpenSource from '../components/OpenSource.astro';
import Links from '../components/Links.astro';
import Footer from '../components/Footer.astro';

const locale = 'en' as const;
---

<BaseLayout locale={locale} canonicalPath="/">
  <Navbar locale={locale} />
  <main>
    <Hero locale={locale} />
    <Features locale={locale} />
    <Architecture locale={locale} />
    <Plugins locale={locale} />
    <OpenSource locale={locale} />
    <Links locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
